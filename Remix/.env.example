# BIAB SDK credentials. Copy to .env.local and fill in.

BIAB_API_KEY=
BIAB_SITE_ID=
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app

# Optional. Defaults to BIAB_API_KEY. If you mint a separate
# analytics-only public key, set it here so the browser bundle
# carries the narrower key rather than the full bearer.
BIAB_PUBLIC_KEY=
