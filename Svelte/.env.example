# Drizzle (local Svelte template default — leave or remove)
DATABASE_URL=file:local.db

# ───────────────────────────────────────────────────────────────────
# BIAB integration env (server-side only — never exposed to client).
# Read in src/lib/server/biab.ts via $env/dynamic/private.
# ───────────────────────────────────────────────────────────────────

# Your BIAB API key (Site Settings → API Keys → New Key).
BIAB_API_KEY=

# The site UUID this app represents.
BIAB_SITE_ID=

# Where BIAB is hosted.
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app

# HMAC secret for the BIAB → consumer revalidate webhook. Paste the
# `whsec_…` value the BIAB admin UI reveals when you add this site
# at /dashboard/settings/integrations.
BIAB_REVALIDATION_SECRET=
