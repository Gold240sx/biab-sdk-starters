# ───────────────────────────────────────────────────────────────────
# BIAB integration env (server-side only).
# Astro runs SSR, so the server reads these via `import.meta.env`
# during render. The browser never sees them.
# ───────────────────────────────────────────────────────────────────

# Your BIAB API key (Site Settings → API Keys → New Key).
BIAB_API_KEY=

# The site UUID this app represents.
BIAB_SITE_ID=

# Where BIAB is hosted. Production:
#   https://www.biab.app
# Local dev:
#   http://localhost:3000
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app

# Optional: HMAC secret for the BIAB → consumer revalidate webhook.
# Paste the `whsec_…` value the BIAB admin UI reveals when you add
# this site at /dashboard/settings/integrations. Required for
# /api/biab/revalidate to verify incoming events.
BIAB_REVALIDATION_SECRET=
