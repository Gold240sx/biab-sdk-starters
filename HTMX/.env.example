# BIAB SDK credentials. Copy to .env.local and fill in.
#
# BIAB_API_KEY     — the public read key from the BIAB dashboard
#                    Settings → API keys. Server-side only here;
#                    HTMX never sees it.
# BIAB_SITE_ID     — the uuid of your site (from the dashboard URL).
# BIAB_PACKAGE_API_BASE_URL — your BIAB instance's origin.
#                    For the BIAB platform itself, https://www.biab.app.
#                    For self-hosted, your own origin.
#
# PORT             — optional. Defaults to 3000.

BIAB_API_KEY=
BIAB_SITE_ID=
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app
PORT=3000
