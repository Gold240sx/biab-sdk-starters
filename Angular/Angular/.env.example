# BIAB SDK credentials. Copy to .env.local and fill in.
#
# BIAB_API_KEY     — the public read key from the BIAB dashboard
#                    Settings → API keys. This is a per-site key,
#                    not your admin token. Safe to ship to the
#                    browser bundle.
# BIAB_SITE_ID     — the uuid of your site (from the dashboard URL).
# BIAB_PACKAGE_API_BASE_URL — your BIAB instance's origin. For
#                    the BIAB platform itself, that's
#                    https://www.biab.app. For a self-hosted
#                    instance, your own origin.

BIAB_API_KEY=
BIAB_SITE_ID=
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app
