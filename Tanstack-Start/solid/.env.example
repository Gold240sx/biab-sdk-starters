# ───────────────────────────────────────────────────────────────────
# BIAB integration env. Server-only — read by createServerFn handlers
# in src/lib/biab.ts. Never prefix with VITE_ or you'll leak them to
# the browser bundle.
# ───────────────────────────────────────────────────────────────────

# Your BIAB API key (Site Settings → API Keys → New Key).
BIAB_API_KEY=

# The site UUID this app represents.
BIAB_SITE_ID=

# Where BIAB is hosted.
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app

# HMAC secret for the BIAB → consumer revalidate webhook.
BIAB_REVALIDATION_SECRET=
