# ───────────────────────────────────────────────────────────────────
# BIAB integration env. Nuxt reads these via `runtimeConfig` (defined
# in nuxt.config.ts), which means the `NUXT_*` prefix is required —
# Nuxt automatically maps NUXT_BIAB_API_KEY → runtimeConfig.biabApiKey.
# All four live under the non-public namespace, so they never leak
# to the client bundle.
# ───────────────────────────────────────────────────────────────────

# Your BIAB API key (Site Settings → API Keys → New Key).
NUXT_BIAB_API_KEY=

# The site UUID this app represents.
NUXT_BIAB_SITE_ID=

# Where BIAB is hosted.
NUXT_BIAB_PACKAGE_API_BASE_URL=https://www.biab.app

# HMAC secret for the BIAB → consumer revalidate webhook.
NUXT_BIAB_REVALIDATION_SECRET=
