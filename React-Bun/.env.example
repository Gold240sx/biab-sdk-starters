# ───────────────────────────────────────────────────────────────────
# BIAB integration env (server-side only — never prefix with VITE_).
# These are read by `server.ts` (the Bun proxy). The Vite browser
# bundle never sees them. Copy to `.env.local` and fill in real
# values from your BIAB workspace.
# ───────────────────────────────────────────────────────────────────

# Your BIAB API key (Site Settings → API Keys → New Key).
BIAB_API_KEY=

# The site UUID this app represents (Dashboard URL or Site Settings).
BIAB_SITE_ID=

# Where BIAB is hosted. Production:
#   https://www.biab.app
# Local dev against a self-hosted BIAB:
#   http://localhost:3000
BIAB_PACKAGE_API_BASE_URL=https://www.biab.app

# Optional: port for the Bun proxy. Defaults to 3000. Vite serves
# the SPA on 5173 and forwards /api/biab/* here (vite.config.ts).
# PORT=3000
